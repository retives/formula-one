{
  "datasets": [
    {
      "displayName": "Gold Overtakes Enriched",
      "name": "gold_overtakes",
      "queryLines": [
        "SELECT\n",
        "  o.driver_number,\n",
        "  o.overtakes_count,\n",
        "  d.full_name,\n",
        "  d.name_acronym,\n",
        "  d.team_name,\n",
        "  d.team_colour\n",
        "FROM\n",
        "  dbr_dev.tokariev_gold.gold_overtakes_driver o\n",
        "    JOIN (\n",
        "      SELECT DISTINCT\n",
        "        driver_number,\n",
        "        full_name,\n",
        "        name_acronym,\n",
        "        team_name,\n",
        "        team_colour\n",
        "      FROM\n",
        "        dbr_dev.tokariev_gold.gold_drivers\n",
        "    ) d\n",
        "      ON o.driver_number = d.driver_number"
      ]
    },
    {
      "displayName": "Gold Driver Laps",
      "name": "gold_laps",
      "queryLines": [
        "SELECT\n",
        "  l.driver_number,\n",
        "  l.lap_duration,\n",
        "  l.duration_sector_1,\n",
        "  l.duration_sector_2,\n",
        "  l.duration_sector_3,\n",
        "  l.i1_speed,\n",
        "  l.i2_speed,\n",
        "  l.st_speed,\n",
        "  l.is_pit_out_lap,\n",
        "  l.lap_number,\n",
        "  l.meeting_key,\n",
        "  l.session_key,\n",
        "  d.full_name,\n",
        "  d.name_acronym,\n",
        "  d.team_name,\n",
        "  d.team_colour\n",
        "FROM\n",
        "  dbr_dev.tokariev_bronze.bronze_laps_duration l\n",
        "    JOIN (\n",
        "      SELECT DISTINCT\n",
        "        driver_number,\n",
        "        full_name,\n",
        "        name_acronym,\n",
        "        team_name,\n",
        "        team_colour\n",
        "      FROM\n",
        "        dbr_dev.tokariev_bronze.bronze_drivers\n",
        "    ) d\n",
        "      ON l.driver_number = d.driver_number"
      ]
    },
    {
      "displayName": "Team Championship",
      "name": "team_championship",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  dbr_dev.tokariev_gold.gold_team_championship"
      ]
    },
    {
